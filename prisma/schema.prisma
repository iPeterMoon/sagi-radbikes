generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model brands {
  id         BigInt     @id(map: "Brand_pkey") @default(autoincrement())
  created_at DateTime   @default(now()) @db.Timestamptz(6)
  name       String?
  products   products[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model categories {
  id          BigInt        @id @default(autoincrement())
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  name        String?       @db.VarChar
  description String?       @db.VarChar
  subcategory subcategory[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model payments {
  id            BigInt   @id(map: "payment_pkey") @default(autoincrement())
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  paymentMethod String?
  amount        Float?
  sale_id       BigInt?
  sales         sales?   @relation(fields: [sale_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "payment_sale_id_fkey")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model product_images {
  id            BigInt   @id @default(autoincrement())
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  image_url     String?
  product_id    BigInt
  is_main_image Boolean?
  products      products @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model product_physical {
  id         BigInt    @id @default(autoincrement())
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  name       String?
  value      String?
  product_id BigInt?
  products   products? @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model products {
  id               BigInt             @id @default(autoincrement())
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  name             String?
  price            Float?             @db.Real
  stock            Int?
  description      String?
  min_stock        Int?
  SKU              String             @unique
  barcode_upc      String?
  is_active        Boolean            @default(true)
  subcategory_id   BigInt?
  brand_id         BigInt?
  product_images   product_images[]
  product_physical product_physical[]
  brands           brands?            @relation(fields: [brand_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "products_metadata_brand_id_fkey")
  subcategory      subcategory?       @relation(fields: [subcategory_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "products_metadata_subcategory_id_fkey")
  sale_details     sale_details[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model roles {
  id          BigInt      @id @default(autoincrement())
  created_at  DateTime    @default(now()) @db.Timestamptz(6)
  name        String
  description String?
  user_role   user_role[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sale_details {
  id         BigInt    @id @default(autoincrement())
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  quantity   Int?      @default(1)
  unitPrice  Float?    @db.Real
  sale_id    BigInt?
  product_id BigInt?
  products   products? @relation(fields: [product_id], references: [id], onDelete: Restrict)
  sales      sales?    @relation(fields: [sale_id], references: [id], onDelete: Cascade)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sales {
  id             BigInt         @id @default(autoincrement())
  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  sold_at        DateTime?      @default(now()) @db.Timestamp(6)
  total          Float?
  user_seller    BigInt?
  folio          String?
  subtotal       Float?
  IVA_amount     Float?
  tax_percentage Float?
  payments       payments[]
  sale_details   sale_details[]
  users          users?         @relation(fields: [user_seller], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model subcategory {
  id          BigInt      @id @default(autoincrement())
  created_at  DateTime    @default(now()) @db.Timestamptz(6)
  name        String?
  category_id BigInt?
  products    products[]
  categories  categories? @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_role {
  id          BigInt   @id @default(autoincrement())
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  role_id     BigInt?
  user_id     BigInt
  description String?
  roles       roles?   @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users       users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id         BigInt      @id(map: "Users_pkey") @default(autoincrement())
  created_at DateTime    @default(now()) @db.Timestamptz(6)
  username   String?     @unique @db.VarChar
  password   String?     @db.VarChar
  sales      sales[]
  user_role  user_role[]
}
